# -----------------------------------------------------------------------------
# Bundler
# -----------------------------------------------------------------------------
/.bundle/
/vendor/bundle

# -----------------------------------------------------------------------------
# Logs & fichiers temporaires Rails
# -----------------------------------------------------------------------------
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

/tmp/pids/*
!/tmp/pids/.keep

# -----------------------------------------------------------------------------
# Stockage local (Active Storage, cache fichiers, SQLite éventuel)
# -----------------------------------------------------------------------------
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# -----------------------------------------------------------------------------
# Secrets — ne jamais versionner
# -----------------------------------------------------------------------------
/config/master.key
/config/credentials/*.key

# Variables d’environnement locales
/.env
/.env.*
!.env.example

# -----------------------------------------------------------------------------
# Assets précompilés (si tu ajoutes un front ou des assets plus tard)
# -----------------------------------------------------------------------------
/public/assets
/public/packs
/public/packs-test

# -----------------------------------------------------------------------------
# Dépendances front (si ajoutées)
# -----------------------------------------------------------------------------
/node_modules
/yarn-error.log
npm-debug.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Outils & qualité
# -----------------------------------------------------------------------------
/coverage/
/.yardoc/
/_yardoc/
/doc/
*.rbc
.rspec_status

# -----------------------------------------------------------------------------
# OS & éditeurs
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Divers
# -----------------------------------------------------------------------------
*.pid
*.seed
*.sqlite3
*.sqlite3-*
